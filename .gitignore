# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1256, check Pipfile.lock into git and use deps from there
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be gitignored or checked in, depending on preference
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be gitignored or checked in, depending on preference
#pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

